NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: enables real server-side AI responses. Without this, AI falls back to the local mock gateway.
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_BASE_URL=https://api.openai.com/v1
AI_TEMPERATURE=0.6
AI_TIMEOUT_MS=45000

# Optional: enables the "Open Test Workspace" button on the sign-in page.
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=
DEMO_ADMIN_NAME=Sandbox Admin

# Optional: enables sending invite emails from the project settings dialog.
RESEND_API_KEY=
INVITE_FROM_EMAIL=Innovation Sandbox <onboarding@resend.dev>
